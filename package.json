{
  "author": {
    "email": "km.8k6ce+npm@gmail.com",
    "name": "kei-g"
  },
  "bugs": {
    "url": "https://github.com/kei-g/bigint-fraction.js/issues"
  },
  "categories": [
    "Data Science"
  ],
  "description": "Fraction composed of bigint",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "c8": "^12.0.0",
    "esbuild": "^0.28.1",
    "esbuild-register": "^3.6.0",
    "mocha": "^11.7.6",
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=14.17.5"
  },
  "homepage": "https://github.com/kei-g/bigint-fraction.js",
  "keywords": [
    "bigfraction",
    "bigint",
    "fraction"
  ],
  "license": "BSD-3-Clause",
  "main": "index.js",
  "name": "bigint-fraction",
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "github:kei-g/bigint-fraction.js",
  "scripts": {
    "build": "npm-run-all2 --parallel clean lint --parallel build:bundle build:tsc",
    "build:bundle": "esbuild src/index.ts --bundle --minify --outfile=index.js --platform=node --target=es2020",
    "build:tsc": "tsc",
    "clean": "rimraf coverage/ index.d.ts index.js lib/",
    "cover": "c8 --check-coverage _mocha",
    "lint": "biome lint --write",
    "postbuild:tsc": "tar -C types/src -cf - . | tar -xf - && rm -fr types",
    "postpublish": "npm run clean",
    "prepublishOnly": "npm run build",
    "start": "node --require esbuild-register src/index.ts",
    "test": "npm-run-all2 --parallel cover lint"
  },
  "types": "index.d.ts",
  "version": "1.0.6"
}
